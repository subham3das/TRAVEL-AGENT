{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EngineResponse",
  "description": "Universal response contract for all compiler stages and engines",
  "type": "object",
  "required": [
    "success",
    "data",
    "errors",
    "warnings",
    "confidence",
    "processingTime",
    "metadata"
  ],
  "properties": {
    "success": {
      "type": "boolean"
    },
    "data": {
      "type": "object"
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "processingTime": {
      "type": "number",
      "description": "Processing time in milliseconds"
    },
    "metadata": {
      "type": "object"
    }
  },
  "additionalProperties": true
}

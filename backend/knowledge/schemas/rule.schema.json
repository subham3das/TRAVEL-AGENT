{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Rule",
  "type": "object",
  "required": [
    "id",
    "type",
    "destinationId",
    "name",
    "category",
    "cashCard",
    "dressCodes",
    "permits",
    "photographyRestrictions",
    "alcoholRules",
    "localCustoms",
    "metadata",
    "version",
    "updatedAt",
    "verifiedAt",
    "tags",
    "sources",
    "confidence"
  ],
  "properties": {
    "id": { "type": "string" },
    "type": { "type": "string", "enum": ["rule"] },
    "destinationId": { "type": "string" },
    "name": { "type": "string" },
    "category": { "type": "string" },
    "cashCard": { "type": "string" },
    "dressCodes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "permits": {
      "type": "array",
      "items": { "type": "string" }
    },
    "photographyRestrictions": { "type": "string" },
    "alcoholRules": { "type": "string" },
    "localCustoms": {
      "type": "array",
      "items": { "type": "string" }
    },
    "metadata": { "type": "object" },
    "version": { "type": "string" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "verifiedAt": { "type": "string", "format": "date-time" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "sources": {
      "type": "array",
      "items": { "type": "string" }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "additionalProperties": false
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Hotel",
  "type": "object",
  "required": [
    "id",
    "type",
    "destinationId",
    "name",
    "category",
    "amenities",
    "location",
    "checkIn",
    "checkOut",
    "familyFriendly",
    "coupleFriendly",
    "metadata",
    "version",
    "updatedAt",
    "verifiedAt",
    "tags",
    "sources",
    "confidence"
  ],
  "properties": {
    "id": { "type": "string" },
    "type": { "type": "string", "enum": ["hotel"] },
    "destinationId": { "type": "string" },
    "name": { "type": "string" },
    "category": { "type": "string" },
    "amenities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "location": {
      "type": "object",
      "required": ["latitude", "longitude", "address"],
      "properties": {
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "address": { "type": "string" }
      }
    },
    "checkIn": { "type": "string" },
    "checkOut": { "type": "string" },
    "familyFriendly": { "type": "boolean" },
    "coupleFriendly": { "type": "boolean" },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "target", "weight", "confidence"],
        "properties": {
          "type": { "type": "string" },
          "target": { "type": "string" },
          "weight": { "type": "number", "minimum": 0, "maximum": 1 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "metadata": { "type": "object" },
    "version": { "type": "string" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "verifiedAt": { "type": "string", "format": "date-time" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "sources": {
      "type": "array",
      "items": { "type": "string" }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "additionalProperties": false
}
